{
    "name": "elpandape/quipu-laravel",
    "description": "Laravel integration for quipu — SUNAT electronic invoicing (CPE Peru). Wires the quipu emitter into the Laravel container, config and facades.",
    "keywords": [
        "sunat",
        "cpe",
        "invoicing",
        "ubl",
        "peru",
        "facturacion-electronica",
        "laravel"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://quipu.elpanda.pe/integraciones/laravel",
    "authors": [
        {
            "name": "ElPandaPe",
            "email": "contacto@elpanda.pe"
        }
    ],
    "support": {
        "issues": "https://github.com/elpandape/quipu-laravel/issues",
        "source": "https://github.com/elpandape/quipu-laravel",
        "docs": "https://quipu.elpanda.pe/integraciones/laravel"
    },
    "require": {
        "php": "^8.4",
        "elpandape/quipu-lite": "^1.0",
        "illuminate/bus": "^12.0 || ^13.0",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/container": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/log": "^12.0 || ^13.0",
        "illuminate/queue": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "elpandape/quipu-pro": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0",
        "spatie/laravel-multitenancy": "^4.1",
        "stancl/tenancy": "^3.10"
    },
    "suggest": {
        "elpandape/quipu-pro": "Enables the Pro capabilities (resilient sender, extra validators, diagnostics, .pfx certificates), auto-detected at runtime."
    },
    "autoload": {
        "psr-4": {
            "ElPandaPe\\QuipuLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElPandaPe\\QuipuLaravel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "review": [
            "php-cs-fixer fix --dry-run --diff",
            "rector process --dry-run",
            "phpstan analyse --memory-limit=1G",
            "pest --type-coverage --min=100",
            "pest --coverage --min=100"
        ],
        "fix": [
            "rector process",
            "php-cs-fixer fix"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "ElPandaPe\\QuipuLaravel\\QuipuServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.elpanda.pe"
        }
    ]
}
